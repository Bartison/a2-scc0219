<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Poções e Soluções</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-container">
    <h1>🧙 Painel Administrativo</h1>
    <p>Gerencie as poções da sua loja</p>

    <div class="form-container">
      <h2>Cadastrar Nova Poção</h2>
      <form id="form-pocao">
        <div class="form-group">
          <label for="nome">Nome da Poção</label>
          <input type="text" id="nome" placeholder="Ex: Poção do Amor" required>
        </div>
        
        <div class="form-group">
          <label for="descricao">Descrição</label>
          <textarea id="descricao" placeholder="Descreva os efeitos da poção..." required></textarea>
        </div>
        
        <div class="form-group">
          <label for="imagem">Link da Imagem</label>
          <input type="text" id="imagem" placeholder="https://i.ibb.co/..." required>
        </div>
        
        <div class="form-group">
          <label for="preco">Preço (em moedas)</label>
          <input type="number" id="preco" placeholder="Ex: 150" required>
        </div>
        
        <button type="submit" class="btn-cadastrar">✨ Cadastrar Poção</button>
      </form>
    </div>

    <hr>

    <div class="lista-container">
      <h2>Poções Cadastradas</h2>
      <div id="lista-admin">
        <% if (pocoes.length === 0) { %>
          <p class="sem-pocoes">Nenhuma poção cadastrada ainda.</p>
        <% } else { %>
          <% pocoes.forEach(p => { %>
            <div class="admin-item" data-id="<%= p.id %>">
              <div class="admin-item-info">
                <img src="<%= p.imagem %>" alt="<%= p.nome %>" class="admin-img">
                <div class="admin-details">
                  <strong><%= p.nome %></strong>
                  <p><%= p.descricao.substring(0, 60) %>...</p>
                  <span class="preco"><%= p.preco %> moedas</span>
                </div>
              </div>
              <button class="btn-remover" data-id="<%= p.id %>">🗑️ Remover</button>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    // Cadastrar via AJAX
    document.getElementById('form-pocao').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const nome = document.getElementById('nome').value;
      const descricao = document.getElementById('descricao').value;
      const imagem = document.getElementById('imagem').value;
      const preco = parseFloat(document.getElementById('preco').value);

      if (!nome || !descricao || !imagem || !preco) {
        alert('Por favor, preencha todos os campos!');
        return;
      }

      try {
        const res = await fetch('/api/pocoes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ nome, descricao, imagem, preco })
        });

        if (res.ok) {
          alert('✅ Poção cadastrada com sucesso!');
          location.reload();
        } else {
          const error = await res.json();
          alert('❌ Erro ao cadastrar: ' + error.error);
        }
      } catch (error) {
        alert('❌ Erro de conexão com o servidor.');
        console.error(error);
      }
    });

    // Remover via AJAX
    document.querySelectorAll('.btn-remover').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        if (!confirm('⚠️ Tem certeza que deseja remover esta poção?')) return;
        
        try {
          const res = await fetch(`/api/pocoes/${id}`, { method: 'DELETE' });
          if (res.ok) {
            alert('✅ Poção removida com sucesso!');
            location.reload();
          } else {
            const error = await res.json();
            alert('❌ Erro ao remover: ' + error.error);
          }
        } catch (error) {
          alert('❌ Erro de conexão com o servidor.');
          console.error(error);
        }
      });
    });
  </script>
</body>
</html>
