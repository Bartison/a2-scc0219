<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Poções e Soluções</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>🧪 Poções e Soluções</h1>
    <p>Desde 1867 no Beco da Última Saída</p>
  </header>

  <section class="historia">
    <h2>Nossa História</h2>
    <p>Fundada em 1867 por <strong>Innabelle Merigold</strong>, a <strong>Poções e Soluções</strong> é uma das lojas mais tradicionais do mundo mágico. Com mais de 150 anos de experiência, oferecemos poções de qualidade incomparável para bruxos e bruxas de todo o mundo.</p>
    <div class="fotos">
      <img src="data:image/jpeg;base64," alt="Loja em 1867">
      <img src="data:image/jpeg;base64," alt="Innabelle Merigold">
    </div>
  </section>

  <section class="produtos">
    <h2>Nossas Poções</h2>
    <div id="lista-pocoes" class="produtos-grid">
      <% pocoes.forEach(p => { %>
        <div class="pocao-card">
          <img src="<%= p.imagem %>" alt="<%= p.nome %>" class="pocao-img">
          <h3><%= p.nome %></h3>
          <p class="descricao"><%= p.descricao %></p>
          <p class="preco"><%= p.preco %> moedas</p>
          <button class="btn-comprar" onclick="alert('Funcionalidade de compra em desenvolvimento!')">Comprar</button>
        </div>
      <% }) %>
    </div>
  </section>

  <footer>
    <div class="footer-content">
      <p><strong>Contato:</strong> (11) 99999-9999 | contato@pocoes-solucoes.com</p>
      <p><strong>Endereço:</strong> Beco da Última Saída, 42 - Londres</p>
      <p><strong>Horário:</strong> Segunda a Sábado, 9h às 18h</p>
    </div>
  </footer>

  <script>
    // Exemplo de AJAX para carregar via API (opcional)
    fetch('/api/pocoes')
      .then(res => res.json())
      .then(data => console.log('Poções via API:', data))
      .catch(err => console.error('Erro ao carregar API:', err));
  </script>
</body>
</html>
